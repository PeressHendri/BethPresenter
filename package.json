    "framer-motion": "^12.38.0",
    "lucide-react": "^0.368.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-contenteditable": "^3.3.7",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "socket.io": "^4.8.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
