{
  "appId": "com.bethpresenter.app",
  "productName": "BethPresenter",
  "copyright": "Copyright © 2026 BethPresenter Youth Bethlehem",
  "asar": true,
  "directories": {
    "output": "release",
    "buildResources": "assets"
  },
  "files": [
    "dist/**/*",
    "main/**/*",
    "node_modules/**/*",
    "prisma/schema.prisma",
    "package.json"
  ],
  "extraResources": [
    {
       "from": "node_modules/.prisma/client",
       "to": "prisma/client",
       "filter": ["*.node"]
    }
  ],
  "win": {
    "icon": "assets/icon.ico",
    "target": ["nsis", "portable"],
    "requestedExecutionLevel": "asInvoker"
  },
  "mac": {
    "icon": "assets/icon.icns",
    "target": ["dmg", "zip"],
    "hardenedRuntime": true,
    "entitlements": "assets/entitlements.mac.plist"
  },
  "linux": {
    "icon": "assets/icon.png",
    "target": ["AppImage", "deb"]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "BethPresenter",
    "installerIcon": "assets/icon.ico",
    "uninstallerIcon": "assets/icon.ico",
    "uninstallDisplayName": "BethPresenter Worship Suite"
  },
  "publish": {
    "provider": "github",
    "owner": "bethlehem-youth",
    "repo": "bethpresenter-desktop",
    "releaseType": "release"
  }
}
